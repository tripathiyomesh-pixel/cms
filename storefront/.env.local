# When using Next.js rewrites, storefront calls /api (relative)
# which Next.js proxies to backend internally - works from any PC/IP
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_WHATSAPP=971500000000
NEXT_PUBLIC_STORE_NAME=Luxury Jewellery
NEXT_PUBLIC_STORE_URL=http://localhost:3011
NEXT_PUBLIC_TEMPLATE=luxury-dark
NEXT_PUBLIC_SHOW_TEMPLATE_SWITCHER=true
INTERNAL_API_URL=http://backend:4000/api
