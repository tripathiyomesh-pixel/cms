FROM node:20-alpine

WORKDIR /app

# dos2unix fixes Windows CRLF line endings in shell scripts
RUN apk add --no-cache dos2unix

COPY package*.json ./
RUN npm install

COPY . .

# Strip CRLF from every shell script in the image — belt and suspenders
RUN find . -name "*.sh" -exec dos2unix {} \; && \
    find . -name "*.sh" -exec chmod +x {} \;

EXPOSE 4000

CMD ["sh", "scripts/start.sh"]
