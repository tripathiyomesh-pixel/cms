FROM node:20-alpine

WORKDIR /app

# Install dos2unix for line ending safety
RUN apk add --no-cache dos2unix

COPY package*.json ./
RUN npm install

COPY . .

# Force Unix line endings on the startup script
RUN dos2unix scripts/start.sh && chmod +x scripts/start.sh

EXPOSE 4000

CMD ["sh", "scripts/start.sh"]
