# ─────────────────────────────────────────────────────────────────────────────
# VANTIX CMS — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_NAME=VantixCMS
FRONTEND_URL=http://localhost:3000

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jewellery_cms
DB_USER=cmsuser
# CHANGE THIS — minimum 20 random characters in production
DB_PASS=CmsPass@2026
DB_SSL=false

# ─── JWT ─────────────────────────────────────────────────────────────────────
# REQUIRED — generate with: openssl rand -hex 64
# ALL services (admin, customer portal, API) use this same secret.
# If unset, the server will warn loudly and use an insecure dev default.
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
JWT_EXPIRE=7d

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASS=your_redis_password   # uncomment if Redis requires auth

# ─── Cloudinary (media uploads) ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
# Used for password reset emails, notifications, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
# For Gmail: use App Password (not your main password)
SMTP_PASS=your_app_password
SMTP_FROM="VantixCMS <noreply@yourdomain.com>"

# ─── Gold Rate API ───────────────────────────────────────────────────────────
# Optional — for live gold rate fetching
# Get key from: https://goldapi.io
GOLD_API_KEY=your_goldapi_key
GOLD_RATE_AUTO_FETCH=false

# ─── RapNet Instant Inventory ────────────────────────────────────────────────
# IMPORTANT: RapNet terms prohibit storing their diamond data in your DB.
# This integration only proxies live data — never persists it.
# Get token from: https://technet.rapaport.com → API → Generate Token
RAPNET_TOKEN=your_rapnet_bearer_token
RAPNET_MARKUP_PCT=5

# ─── Vantix ERP Integration ──────────────────────────────────────────────────
ERP_API_URL=https://your-erp-domain.com
ERP_API_KEY=your_erp_api_key_here
ERP_WEBHOOK_SECRET=your_hmac_secret_here
ERP_SYNC_ENABLED=false
ERP_SYNC_INTERVAL_MINUTES=15

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
